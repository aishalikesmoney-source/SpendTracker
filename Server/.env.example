# ──────────────────────────────────────────────────────────────
# SpendTrack Server — Environment Configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# Plaid API Credentials
# Get these from: https://dashboard.plaid.com/team/keys
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_sandbox_secret_here

# Environment: sandbox | development | production
# - sandbox: Free, uses test credentials (user: user_good, pass: pass_good)
# - development: Real bank connections, limited to 100 items (free)
# - production: Real bank connections, requires Plaid approval
PLAID_ENV=sandbox

# Optional: Plaid OAuth redirect URI (needed for OAuth banks like Chase, BofA)
# Must match exactly what you register in the Plaid dashboard
# PLAID_REDIRECT_URI=https://your-production-domain.com/oauth

# Server port (default: 3000)
PORT=3000
